{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "remote-window-controls",
  "description": "Le site (contenu distant) pilote sa fenêtre (barre de titre custom façon Discord), le zoom natif (Options → Launcher), l'ouverture de LIENS EXTERNES dans le navigateur par défaut (opener) et les TOASTS système (notification). Rien d'autre n'est exposé au contenu distant.",
  "remote": {
    "urls": [
      "https://www.geeklearngames.com",
      "https://geeklearngames.com"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:webview:allow-set-webview-zoom",
    "notification:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }, { "url": "mailto:*" }]
    }
  ]
}
